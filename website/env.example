# LiBeDAW Website — Environment Variables
# Copy this file to .env and fill in your values

# ── Site Domain ───────────────────────────────────────────────────────────────
# The public domain Traefik will route to this container
# Example: libedaw.example.com
SITE_DOMAIN=libedaw.example.com

# ── Container / Image ─────────────────────────────────────────────────────────
# Docker image tag (default: latest)
IMAGE_TAG=latest

# Local port to bind if not using Traefik (default: 8080)
# Only used for local development — in production Traefik handles routing
HOST_PORT=8080

# ── Network ───────────────────────────────────────────────────────────────────
# Name of the Docker network to join
# Set NETWORK_EXTERNAL=true if using a shared Traefik network (e.g. "proxy")
NETWORK_NAME=libedaw-web
NETWORK_EXTERNAL=false

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris
